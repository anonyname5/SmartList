<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container_compact"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    android:background="@drawable/smartlist_widget_background"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/widget_compact_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SmartList"
        android:textColor="#1F3A5F"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_compact_targets"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Today: 0"
        android:textColor="#1D2733"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/widget_compact_remaining"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Remain: RM0.00"
        android:textColor="#1D2733"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
